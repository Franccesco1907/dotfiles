{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "--package=@upstash/context7-mcp@2.2.5",
        "--",
        "context7-mcp"
      ]
    },
    "engram": {
      "args": [
        "mcp",
        "--tools=agent"
      ],
      "command": "/opt/homebrew/bin/engram"
    }
  }
}
